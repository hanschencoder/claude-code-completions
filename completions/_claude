_claude_plugins_marketplace() {
  local context state state_descr line
  typeset -A opt_args

  _arguments -C \
    '(-h,--help)'{-h,--help}'[Display help for command]' \
    '1: :->command' \
    '*:: :->args' \
  && return 0

  case $state in
    command)
      local -a subcommands
      subcommands=(
        'add:Add a marketplace from a URL, path, or GitHub repo'
        'help:display help for command'
        'list:List all configured marketplaces'
        'remove:Remove a configured marketplace'
        'rm:Remove a configured marketplace'
        'update:Update marketplace(s) from their source - updates all if no name specified'
      )
      _describe 'command' subcommands
      ;;
    args)
      case $line[1] in
        add)
          _claude_plugins_marketplace_add
          ;;
        help)
          _claude_plugins_marketplace_help
          ;;
        list)
          _claude_plugins_marketplace_list
          ;;
        remove)
          _claude_plugins_marketplace_remove
          ;;
        rm)
          _claude_plugins_marketplace_rm
          ;;
        update)
          _claude_plugins_marketplace_update
          ;;
      esac
      ;;
  esac
}

